enum class PieceState {
    Idle,       // על הלוח, אינו בתנועה
    Moving,     // נמצא בדרך ליעד
    Captured,   // הוסר מהמשחק
    Airborne    // כלי שנמצא כרגע בעיצומה של קפיצה באוויר
};

