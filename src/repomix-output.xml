    // בזמן בניית ה-Snapshot, כדי שכל צרכן (View) לא יצטרך לבצע חיפוש נוסף
    // אחר הכלי בלוח כדי לשאול את ה-Arbiter בעצמו.
    float cooldownProgress = 0.0f;
};

struct GameSnapshot {
    int boardCols;
    int boardRows;
    std::vector<PieceSnapshot> pieces;
    std::optional<Position> selectedCell;
    bool isGameOver;
};

