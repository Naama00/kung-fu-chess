<file path="server/MatchManager.hpp">
#pragma once

#include <unordered_map>
#include <memory>
#include <mutex>
#include <vector>
#include "../engine/core/GameEngine.hpp"
#include "NetworkMessages.hpp"

namespace kungfu {

struct LiveMatch {
    std::uint64_t matchId;
    std::unique_ptr<GameEngine> engine;
    std::uint64_t playerWhiteSessionId;
    std::uint64_t playerBlackSessionId;
};

class MatchManager {
public:
    MatchManager() : m_nextMatchId(1) {}

    // יצירת משחק חדש עם הרכיבים הנדרשים ל-GameEngine
    std::uint64_t createMatch(std::uint64_t playerWhite, std::uint64_t playerBlack,
                              std::shared_ptr<IBoard> board,
                              std::shared_ptr<RuleEngine> ruleEngine) {
        std::lock_guard<std::mutex> lock(m_mutex);
        
        std::uint64_t id = m_nextMatchId++;
        auto match = std::make_unique<LiveMatch>();
        match->matchId = id;
        
        // אתחול ה-GameEngine הקיים שלך בשרת
        match->engine = std::make_unique<GameEngine>(board, ruleEngine); 
        match->playerWhiteSessionId = playerWhite;
        match->playerBlackSessionId = playerBlack;
        
        m_matches[id] = std::move(match);
        return id;
    }

    /// @brief מעבד מהלך יחיד ומחזיר את הסטטוס שלו (Accepted/Rejected/Pending)
    ActionResult processMove(std::uint64_t matchId, const ActionRequest& request) {
        std::lock_guard<std::mutex> lock(m_mutex);
        
        auto it = m_matches.find(matchId);
        if (it == m_matches.end()) {
            // אם המשחק לא נמצא, נחזיר דחייה כברירת מחדל
            return ActionResult(request.requestId, ActionStatus::Rejected);
        }
        
        // מנוע המשחק מקבל וקטור של בקשות. נכניס את הבקשה היחידה שלנו
        std::vector<ActionRequest> requests = { request };
        std::vector<ActionResult> results = it->second->engine->processActionRequests(requests);
        
        // מאחר ושלחנו בקשה אחת, נקבל תוצאה אחת בחזרה
        if (!results.empty()) {
            return results.front();
        }
        
        return ActionResult(request.requestId, ActionStatus::Rejected);
    }

    bool getMatchPlayers(std::uint64_t matchId, std::uint64_t& outWhite, std::uint64_t& outBlack) {
        std::lock_guard<std::mutex> lock(m_mutex);
        auto it = m_matches.find(matchId);
        if (it == m_matches.end()) return false;
        
        outWhite = it->second->playerWhiteSessionId;
        outBlack = it->second->playerBlackSessionId;
        return true;
    }

    // בדיקה האם המשחק הסתיים (כדי שהשרת יוכל לנקות משאבים)
    bool isMatchOver(std::uint64_t matchId) {
        std::lock_guard<std::mutex> lock(m_mutex);
        auto it = m_matches.find(matchId);
        if (it != m_matches.end()) {
            return it->second->engine->isGameOver();
        }
        return true;
    }

private:
    std::unordered_map<std::uint64_t, std::unique_ptr<LiveMatch>> m_matches;
    std::uint64_t m_nextMatchId;
    std::mutex m_mutex;
};

} // namespace kungfu
</file>

<file path="server/NetworkMessages.hpp">
#pragma once

#include <cstdint>
#include <vector>


namespace kungfu {

// סוגי ההודעות ברשת
enum class NetworkMessageType : std::uint8_t {
    JOIN_MATCH_REQUEST,  // לקוח מבקש להצטרף למשחק
    MATCH_FOUND,         // השרת מודיע שמצא משחק ומחזיר צבע ומזהה משחק
    GAME_MOVE,           // שליחת מהלך (מלקוח לשרת או משרת ללקוח)
    MOVE_RESULT          // השרת מחזיר את תוצאת המהלך (חוקי/לא חוקי)
    HEARTBEAT            // הודעת סיגנל קטנה לשמירה על החיבור
};

// ייצוג קומפקטי של Position למעבר ברשת
struct NetworkPosition {
    std::int32_t x;
    std::int32_t y;
};

// המבנה הקבוע של הודעת מהלך שעוברת בסוקט
struct NetworkMovePacket {
    std::uint64_t matchId;
    std::uint64_t requestId;
    std::uint8_t  playerColor; // מומר מ-PlayerColor
    NetworkPosition from;
    NetworkPosition to;
};

// כותרת כללית לכל חבילה ברשת כדי שהשרת ידע איך לקרוא את ההמשך
struct NetworkHeader {
    NetworkMessageType type;
    std::uint32_t payloadSize; // אורך הנתונים שבאים מיד אחרי הכותרת
};

} // namespace kungfu
</file>

<file path="server/NetworkServer.hpp">
#pragma once

#include <boost/asio.hpp>
#include <memory>
#include <vector>
#include <iostream>
#include "Serializer.hpp"
#include "MatchManager.hpp"

namespace kungfu {

using boost::asio::ip::tcp;

class NetworkSession : public std::enable_shared_from_this<NetworkSession> {
public:
    NetworkSession(tcp::socket socket, MatchManager& matchManager)
        : m_socket(std::move(socket)), m_matchManager(matchManager), m_matchId(0) {}

    void start() {
        readHeader();
    }

    // שליחת תוצאה חזרה ללקוח באופן אסינכרוני
    void sendActionResult(const ActionResult& result) {
        auto self = shared_from_this();
        
        // 1. סיראליזציה של גוף התשובה
        auto payload = Serializer::serializeActionResult(result);
        
        // 2. בניית כותרת מתאימה
        NetworkHeader header{ MessageType::ActionResult, static_cast<std::uint32_t>(payload.size()) };
        auto headerBuffer = Serializer::serializeHeader(header);
        
        // 3. איחוד הכותרת והגוף למאגר אחד לשליחה אטומית
        auto writeBuffer = std::make_shared<std::vector<std::uint8_t>>(std::move(headerBuffer));
        writeBuffer->insert(writeBuffer->end(), payload.begin(), payload.end());

        boost::asio::async_write(m_socket, boost::asio::buffer(*writeBuffer),
            [self, writeBuffer](boost::system::error_code ec, size_t /*length*/) {
                if (ec) {
                    std::cerr << "Session write error: " << ec.message() << std::endl;
                }
            });
    }

    void setMatchId(std::uint64_t matchId) { m_matchId = matchId; }

private:
    void readHeader() {
        auto self = shared_from_this();
        m_readBuffer.resize(Serializer::HEADER_SIZE);

        boost::asio::async_read(m_socket, boost::asio::buffer(m_readBuffer),
            [self](boost::system::error_code ec, size_t /*length*/) {
                if (!ec) {
                    try {
                        NetworkHeader header = Serializer::deserializeHeader(self->m_readBuffer);
                        self->readPayload(header);
                    } catch (const std::exception& e) {
                        std::cerr << "Header parsing error: " << e.what() << std::endl;
                    }
                }
            });
    }

    void readPayload(NetworkHeader header) {
        auto self = shared_from_this();
        m_readBuffer.resize(header.payloadSize);

        boost::asio::async_read(m_socket, boost::asio::buffer(m_readBuffer),
            [self, header](boost::system::error_code ec, size_t /*length*/) {
                if (!ec) {
                    try {
                        if (header.type == MessageType::ActionRequest) {
                            ActionRequest req = Serializer::deserializeActionRequest(self->m_readBuffer);
                            
                            // עיבוד המהלך דרך ה-MatchManager שחיברנו קודם!
                            ActionResult res = self->m_matchManager.processMove(self->m_matchId, req);
                            
                            // שליחת התשובה חזרה ללקוח
                            self->sendActionResult(res);
                        }
                        
                        // המשך האזנה להודעה הבאה מאותו לקוח
                        self->readHeader();
                    } catch (const std::exception& e) {
                        std::cerr << "Payload processing error: " << e.what() << std::endl;
                    }
                }
            });
    }

    tcp::socket m_socket;
    MatchManager& m_matchManager;
    std::uint64_t m_matchId;
    std::vector<std::uint8_t> m_readBuffer;
};

class NetworkServer {
public:
    NetworkServer(boost::asio::io_context& ioContext, std::uint16_t port, MatchManager& matchManager)
        : m_acceptor(ioContext, tcp::endpoint(tcp::v4(), port)), m_matchManager(matchManager) {
        startAccept();
    }

private:
    void startAccept() {
        m_acceptor.async_accept(
            [this](boost::system::error_code ec, tcp::socket socket) {
                if (!ec) {
                    std::cout << "New player connection accepted!" << std::endl;
                    std::make_shared<NetworkSession>(std::move(socket), m_matchManager)->start();
                }
                startAccept(); // המשך קבלת חיבורים נוספים
            });
    }

    tcp::acceptor m_acceptor;
    MatchManager& m_matchManager;
};

} // namespace kungfu
</file>

<file path="server/Serializer.hpp">
#pragma once

#include "NetworkMessages.hpp"
#include "../engine/core/GameEngine.hpp"
#include <cstring>

namespace kungfu {

class Serializer {
public:
    // תרגום חבילת רשת לבקשת מנוע
    static ActionRequest deserializeToRequest(const NetworkMovePacket& packet) {
        // המרת המידע מהרשת למבנה שהמנוע שלך דורש
        // כאן אנחנו מניחים ש-PlayerAction מכיל את הקואורדינטות from/to
        PlayerAction action;
        action.from = {packet.from.x, packet.from.y};
        action.to   = {packet.to.x, packet.to.y};

        return ActionRequest(packet.requestId, static_cast<PlayerColor>(packet.playerColor), action);
    }

    // תרגום תוצאת מנוע לחבילת רשת
    static ActionResult deserializeToResult(const std::vector<std::uint8_t>& buffer) {
        // כאן נבצע קריאה של המבנה מהסוקט
        ActionResult result(0, ActionStatus::REJECTED);
        std::memcpy(&result, buffer.data(), sizeof(ActionResult));
        return result;
    }
};

} // namespace kungfu
</file>

<file path="ui/components/BoardView.hpp">
#pragma once

#include "ui/framework/IRenderer.hpp"
#include "ui/framework/InputEvents.hpp"
#include "engine/snapshot/GameSnapshot.hpp"
#include "engine/core/PremoveQueue.hpp"
#include "engine/common/PieceTokenCodec.hpp"
#include "ui/components/CooldownBar.hpp"
#include <unordered_map>
#include <optional>
#include <cmath>

class BoardView {
private:
    CooldownBar m_cooldownBar; // מד הצינון מנוהל כעת פנימית ברכיב הלוח

    static int positionKey(const kungfu::Position &pos, int cols) {
        return pos.row() * cols + pos.col();
    }

public:
    BoardView() = default;
    ~BoardView() = default;

    BoardView(const BoardView&) = delete;
    BoardView& operator=(const BoardView&) = delete;

    /**
     * פונקציית הציור הראשית של לוח המשחק.
     */
    void draw(IRenderer& renderer,
              const kungfu::view::GameSnapshot& snapshot,
              const kungfu::PremoveQueue& premoveQueue,
              float boardStartX,
              float boardStartY,
              float boardRangeX,
              float boardRangeY,
              int hoveredRow,
              int hoveredCol,
              bool isHovering,
              bool isJumping,
              float jumpTimer,
              bool isPaused,
              bool allowSimultaneous) const
    {
        int rows = snapshot.boardRows;
        int cols = snapshot.boardCols;

        float cellWidth = boardRangeX / cols;
        float cellHeight = boardRangeY / rows;

        // --- 1. ציור רקע הלוח והמסגרות הקישוטיות ---
        Color boardFrameBg{35, 36, 43, 255};
        Color boardFrameBorder{65, 68, 85, 255};

        renderer.drawRectangle({boardStartX - 8.0f, boardStartY - 8.0f},
                               {boardRangeX + 16.0f, boardRangeY + 16.0f},
                               boardFrameBg, true);
        renderer.drawRectangle({boardStartX - 8.0f, boardStartY - 8.0f},
                               {boardRangeX + 16.0f, boardRangeY + 16.0f},
                               boardFrameBorder, false);

        // --- 2. ציור הרשת (Grid), בחירה (Selection) וריחוף (Hover) ---
        Color lightTile{238, 238, 210, 255};
        Color darkTile{118, 150, 86, 255};
        Color hoverBorderColor{0, 229, 255, 200};
        Color selectedTileColor{244, 246, 128, 110};
        Color selectedBorderColor{244, 246, 128, 255};

        for (int r = 0; r < rows; ++r) {
            for (int c = 0; c < cols; ++c) {
                Vector2D pos{boardStartX + c * cellWidth, boardStartY + r * cellHeight};
                Vector2D size{cellWidth, cellHeight};

                Color tileColor = ((r + c) % 2 == 0) ? lightTile : darkTile;
                renderer.drawRectangle(pos, size, tileColor, true);

                // סימון ריחוף עכבר מעל משבצת
                if (hoveredRow == r && hoveredCol == c) {
                    renderer.drawRectangle({pos.x + 1.0f, pos.y + 1.0f}, {size.x - 2.0f, size.y - 2.0f}, hoverBorderColor, false);
                }
            }
        }

        // סימון משבצת שנבחרה
        auto selectedOpt = snapshot.selectedCell;
        if (selectedOpt.has_value() && !isPaused && !snapshot.isGameOver) {
            Vector2D pos{selectedOpt->col() * cellWidth, boardStartY + selectedOpt->row() * cellHeight};
            Vector2D size{cellWidth, cellHeight};
            renderer.drawRectangle(pos, size, selectedTileColor, true);
            renderer.drawRectangle(pos, size, selectedBorderColor, false);
        }

        // --- 3. ציור הכלים, אפקטי קפיצה וצינונים (Cooldowns) ---
        std::unordered_map<int, Vector2D> piecePositions; // מעקב אחר המיקום הפיזי של הכלים לצורך ציור חיצי ה-Premoves

        for (const auto &pieceSnap : snapshot.pieces) {
            std::string assetId = (pieceSnap.color == kungfu::PlayerColor::White) ? "w" : "b";
            assetId += kungfu::PieceTokenCodec::toChar(pieceSnap.type);

            float animatedX = pieceSnap.pixelX;
            float animatedY = boardStartY + pieceSnap.pixelY;

            // אנימציות ריחוף וקפיצה של כלי מסומן
            if (selectedOpt.has_value() &&
                pieceSnap.logicalPosition.row() == selectedOpt->row() &&
                pieceSnap.logicalPosition.col() == selectedOpt->col())
            {
                if (isHovering) {
                    float floatOffset = 25.0f + std::sin(jumpTimer * 5.0f) * 6.0f;
                    animatedY -= floatOffset;
                } else if (isJumping) {
                    float bounceOffset = std::abs(std::sin(jumpTimer * 12.0f)) * 22.0f;
                    animatedY -= bounceOffset;
                }
            }

            Vector2D spritePos{animatedX, animatedY};
            Vector2D spriteSize{cellWidth, cellHeight};

            float padding = cellWidth * 0.10f;
            renderer.drawSprite(assetId, {spritePos.x + padding, spritePos.y + padding}, {spriteSize.x - (padding * 2), spriteSize.y - (padding * 2)});

            // רינדור אפקטים חזותיים של צינון
            if (allowSimultaneous && pieceSnap.cooldownProgress > 0.0f) {
                Vector2D center{animatedX + cellWidth / 2.0f, animatedY + cellHeight / 2.0f};
                float radius = cellWidth * 0.42f;

                float startAngle = -90.0f;
                float endAngle = -90.0f + (360.0f * pieceSnap.cooldownProgress);

                Color radialColor{180, 35, 35, 110};
                renderer.drawSector(center, radius, startAngle, endAngle, radialColor, true);
                renderer.drawCircle(center, radius, {220, 50, 50, 90}, false);

                m_cooldownBar.draw(renderer, center, pieceSnap.cooldownProgress);
            }

            piecePositions[positionKey(pieceSnap.logicalPosition, cols)] = spritePos;
        }

        // --- 4. ציור מהלכי Premoves וחיבור קווים מנחים ---
        if (!isPaused && !snapshot.isGameOver) {
            for (const auto &entry : premoveQueue.entries()) {
                auto piece = entry.first;
                auto to = entry.second;
                if (!piece) continue;

                float destX = to.col() * cellWidth;
                float destY = boardStartY + to.row() * cellHeight;

                Color premoveColor{255, 107, 107, 70};
                Color premoveBorderColor{255, 107, 107, 200};

                renderer.drawRectangle({destX, destY}, {cellWidth, cellHeight}, premoveColor, true);
                renderer.drawRectangle({destX, destY}, {cellWidth, cellHeight}, premoveBorderColor, false);

                Vector2D startPt{0.0f, 0.0f};
                auto it = piecePositions.find(positionKey(piece->position(), cols));
                if (it != piecePositions.end()) {
                    startPt.x = it->second.x + cellWidth / 2.0f;
                    startPt.y = it->second.y + cellHeight / 2.0f;
                } else {
                    startPt.x = piece->position().col() * cellWidth + cellWidth / 2.0f;
                    startPt.y = boardStartY + piece->position().row() * cellHeight + cellHeight / 2.0f;
                }

                Vector2D endPt{destX + cellWidth / 2.0f, destY + cellHeight / 2.0f};
                renderer.drawLine(startPt, endPt, premoveBorderColor, 3.0f);
            }
        }
    }
};
</file>

<file path="ui/components/Button.hpp">
// מחלקה זו מייצגת כפתור לוגי. היא מנהלת את המצב הוויזואלי שלו 
// (רגיל, ריחופית - Hover, או לחוץ) ומזהה לחיצות במערכת הצירים הלוגית
#pragma once
#include "ui/framework/InputEvents.hpp"
#include <string>
#include <string_view>
#include <functional>
#include "ui/framework/IRenderer.hpp"

class Button {
private:
    Vector2D m_position;
    Vector2D m_size;
    std::string m_text;
    
    Color m_normalColor{60, 60, 60, 255};
    Color m_hoverColor{90, 90, 90, 255};
    Color m_textColor{255, 255, 255, 255};
    
    bool m_isHovered = false;
    std::function<void()> m_onClickCallback;

public:
    Button(Vector2D position, Vector2D size, std::string text, std::function<void()> onClickCallback)
        : m_position(position), m_size(size), m_text(std::move(text)), m_onClickCallback(std::move(onClickCallback)) {}

    // עדכון מצב הכפתור (למשל לצורך אנימציות עתידיות)
    void update(float deltaTime) {
        (void)deltaTime; // כרגע ללא שימוש
    }

    // ציור הכפתור באמצעות ה-Renderer האבסטרקטי
    void draw(IRenderer& renderer) const {
        Color currentBg = m_isHovered ? m_hoverColor : m_normalColor;
        
        // ציור הרקע של הכפתור
        renderer.drawRectangle(m_position, m_size, currentBg, true);
        
        // ציור מסגרת דקה
        renderer.drawRectangle(m_position, m_size, {120, 120, 120, 255}, false);
        
        // חישוב מיקום טקסט מקורב למרכז (ניתן לשפר בהתאם ליכולות רינדור הטקסט של ה-Renderer)
        Vector2D textPos{m_position.x + 15.0f, m_position.y + (m_size.y * 0.3f)};
        renderer.drawText(m_text, textPos, 16, m_textColor);
    }

    // טיפול בקלט ובדיקת אינטראקציה עם העכבר
    void handleInput(const MouseEvent& mouseEvent) {
        // בדיקה האם העכבר נמצא מעל שטח הכפתור הלוגי
        m_isHovered = (mouseEvent.logicalX >= m_position.x && 
                       mouseEvent.logicalX <= m_position.x + m_size.x &&
                       mouseEvent.logicalY >= m_position.y && 
                       mouseEvent.logicalY <= m_position.y + m_size.y);

        // אם בוצעה לחיצה כשהעכבר מעל הכפתור, מפעילים את ה-Callback
        if (m_isHovered && mouseEvent.action == MouseEvent::Action::Press && mouseEvent.button == MouseButton::Left) {
            if (m_onClickCallback) {
                m_onClickCallback();
            }
        }
    }

    // הגדרת צבעים מותאמים אישית
    void setColors(Color normal, Color hover, Color text) {
        m_normalColor = normal;
        m_hoverColor = hover;
        m_textColor = text;
    }
};
