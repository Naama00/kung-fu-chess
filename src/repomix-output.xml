namespace kungfu {

using boost::asio::ip::tcp;

class NetworkPlayer : public IPlayer, public std::enable_shared_from_this<NetworkPlayer> {
public:
    NetworkPlayer(boost::asio::io_context& ioContext, const std::string& host, const std::string& port);
    
    // מימוש מתודות הממשק הקיים של IPlayer
    virtual void decideAction(std::uint64_t requestId, std::function<void(PlayerAction)> callback) override;
    virtual void onActionResult(const ActionResult& result) override;

    // חיבור ראשוני לשרת ושליחת בקשת הצטרפות
    void connectAndJoin();

private:
    void sendMoveToServer(std::uint64_t requestId, const PlayerAction& action);
    void listenForServerResponse();

    boost::asio::io_context& m_ioContext;
