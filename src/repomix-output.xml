#include <boost/asio.hpp>
#include <iostream>
#include <memory>
#include "NetworkServer.hpp"
#include "MatchManager.hpp"

int main() {
    try {
        // 1. הגדרת הפורט עליו יאזין השרת
        const std::uint16_t port = 8080;

        // 2. יצירת לולאת האירועים המרכזית של Boost.Asio
        boost::asio::io_context ioContext;

        // 3. אתחול מנהל המשחקים (הלוגיקה הסטטית/מנוע המשחק)
        kungfu::MatchManager matchManager;

        std::cout << "Starting KungFu Chess Server on port " << port << "..." << std::endl;

        // 4. אתחול השרת והתחלת האזנה אסינכרונית לחיבורים נכנסים
        kungfu::NetworkServer server(ioContext, port, matchManager);

        std::cout << "Server is running. Waiting for players to connect..." << std::endl;

        // 5. הרצת לולאת האירועים - שורה זו חוסמת את ה-Thread הראשי
        // ומנהלת את כל הקריאות, הכתיבות והחיבורים בצורה אסינכרונית יעילה
        ioContext.run();

    } catch (const std::exception& e) {
        std::cerr << "Fatal Server Error: " << e.what() << std::endl;
        return 1;
    }

    return 0;
}
