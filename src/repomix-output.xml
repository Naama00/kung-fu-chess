<file path="players/network/NetworkPlayer.cpp">
#include "NetworkPlayer.hpp"
#include "../../server/Serializer.hpp"
#include <iostream>

namespace kungfu {

NetworkPlayer::NetworkPlayer(boost::asio::io_context& ioContext, const std::string& host, const std::string& port)
    : m_ioContext(ioContext), m_socket(ioContext), m_host(host), m_port(port), m_matchId(0), m_assignedColor(0) {}

void NetworkPlayer::connectAndJoin() {
    tcp::resolver resolver(m_ioContext);
    auto endpoints = resolver.resolve(m_host, m_port);

    boost::asio::async_connect(m_socket, endpoints,
        [this](boost::system::error_code ec, tcp::endpoint) {
            if (!ec) {
                std::cout << "Connected to game server successfully!" << std::endl;
                
                // שליחת בקשת הצטרפות ראשונית לשרת
                NetworkHeader header{ NetworkMessageType::JOIN_MATCH_REQUEST, 0 };
                auto buffer = Serializer::serializeHeader(header);
                
                boost::asio::async_write(m_socket, boost::asio::buffer(buffer),
                    [this](boost::system::error_code writeEc, size_t) {
                        if (!writeEc) {
                            // מתחילים להאזין לתשובות מהשרת (כמו MATCH_FOUND)
                            listenForServerResponse();
                        }
                    });
            } else {
                std::cerr << "Connection failed: " << ec.message() << std::endl;
            }
        });
}

void NetworkPlayer::decideAction(std::uint64_t requestId, std::function<void(PlayerAction)> callback) {
    // מנוע המשחק המקומי מבקש מהשחקן הזה לבצע מהלך.
    // מכיוון שמדובר בשחקן רשת, אנחנו שומרים את ה-Callback ומחכים שהמהלך יגיע מהסוקט.
    m_pendingActionCallback = callback;
}

void NetworkPlayer::onActionResult(const ActionResult& result) {
    // עדכון השחקן המקומי לגבי תוצאת המהלך האחרון שבוצע
    // כאן נשלח הודעה מסוג MOVE_RESULT לשרת במידת הצורך
}

void NetworkPlayer::listenForServerResponse() {
    auto buffer = std::make_shared<std::vector<std::uint8_t>>(Serializer::HEADER_SIZE);

    boost::asio::async_read(m_socket, boost::asio::buffer(*buffer),
        [this, buffer](boost::system::error_code ec, size_t) {
            if (!ec) {
                NetworkHeader header = Serializer::deserializeHeader(*buffer);
                
                // קריאת ה-Payload בהתאם לגודל שהתקבל בכותרת
                auto payloadBuffer = std::make_shared<std::vector<std::uint8_t>>(header.payloadSize);
                boost::asio::async_read(m_socket, boost::asio::buffer(*payloadBuffer),
                    [this, header, payloadBuffer](boost::system::error_code payloadEc, size_t) {
                        if (!payloadEc) {
                            if (header.type == NetworkMessageType::MATCH_FOUND) {
                                // קבלת מזהה המשחק והצבע שהוקצה מהשרת
                                std::memcpy(&m_matchId, payloadBuffer->data(), sizeof(m_matchId));
                                std::memcpy(&m_assignedColor, payloadBuffer->data() + sizeof(m_matchId), sizeof(m_assignedColor));
                                std::cout << "Match found! ID: " << m_matchId << " As Color: " << (int)m_assignedColor << std::endl;
                            }
                            else if (header.type == NetworkMessageType::GAME_MOVE) {
                                // הגיע מהלך מהיריב דרך השרת
                                NetworkMovePacket packet;
                                std::memcpy(&packet, payloadBuffer->data(), sizeof(NetworkMovePacket));
                                
                                // המרה ל-PlayerAction של המנוע
                                PlayerAction action;
                                action.from = { packet.from.x, packet.from.y };
                                action.to = { packet.to.x, packet.to.y };

                                // הפעלת ה-Callback כדי לעדכן את לולאת המשחק המקומית
                                if (m_pendingActionCallback) {
                                    m_pendingActionCallback(action);
                                    m_pendingActionCallback = nullptr;
                                }
                            }
                            
                            // המשך האזנה להודעות הבאות
                            listenForServerResponse();
                        }
                    });
            }
        });
}

} // namespace kungfu
</file>

